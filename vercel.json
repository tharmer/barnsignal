{
  "functions": {
    "api/index.ts": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    {
      "path": "/api/cron/fetch",
      "schedule": "0 20 * * 1,2,3,4"
    },
    {
      "path": "/api/cron/predict",
      "schedule": "0 21 * * 1,2,3,4"
    }
  ]
}
